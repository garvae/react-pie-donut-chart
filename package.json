{
  "version": "1.0.3",
  "description": "Lightweight library allows you to create \"pie\" and \"donut\" charts easily",
  "keywords": [
    "arc",
    "arc-chart",
    "area-chart",
    "chart",
    "charting",
    "charts",
    "component",
    "data visualization",
    "donut-chart",
    "pie",
    "pie-chart",
    "radial",
    "react",
    "react-component",
    "reactjs",
    "svg",
    "typescript",
    "visualization"
  ],
  "homepage": "https://github.com/garvae/react-pie-donut-chart",
  "funding": {
    "url": "https://ko-fi.com/garvae"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/garvae/react-pie-donut-chart"
  },
  "bugs": {
    "url": "https://github.com/garvae/react-pie-donut-chart/issues"
  },
  "license": "MIT",
  "main": "dist/index.js",
  "umd:main": "dist/index.js",
  "module": "dist/react-pie-donut-chart.esm.js",
  "typings": "dist/types/index.d.ts",
  "files": ["*.d.ts", "dist"],
  "engines": {
    "node": ">=10"
  },
  "scripts": {
    "analyze": "size-limit",
    "build": "npm run rollup:compile",
    "build:index-cleanup": "node scripts/clean-dist-index.js",
    "copy:license": "cpx LICENSE dist",
    "copy:readme": "cpx README.md dist",
    "copy:types": "cpx src/types/index.d.ts dist",
    "delete:dist": "rimraf dist",
    "delete:sourcemaps": "del dist/**/*.js.map",
    "generate:packagejson": "node scripts/generate-package-json.js",
    "generate:ts-config": "node scripts/generate-ts-config.js && biome format --write tsconfig.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:js": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "postbuild": "npm run build:index-cleanup && npm run generate:packagejson && npm run copy:license && npm run copy:types && npm run copy:readme",
    "postinstall": "husky install",
    "postprepare": "npm run generate:packagejson",
    "pre-commit": "npm run check && npm run test",
    "prebuild": "npm run generate:ts-config && npm run delete:dist && npm run check",
    "prepare": "husky install",
    "pretest": "npm run generate:ts-config",
    "publish:dist": "cd dist && npm publish",
    "rollup:compile": "rollup src/index.ts --file dist/index.js --format cjs -c rollup.config.js",
    "size": "size-limit",
    "test": "jest",
    "test:cover": "jest --collect-coverage",
    "version:patch": "npm version patch"
  },
  "resolutions": {
    "react-error-overlay": "6.0.9"
  },
  "pnpm": {
    "overrides": {
      "react-error-overlay": "6.0.9"
    },
    "onlyBuiltDependencies": ["core-js", "esbuild", "node-sass", "pre-commit", "spawn-sync"]
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  },
  "peerDependencies": {
    "react": ">=16"
  },
  "name": "@garvae/react-pie-donut-chart",
  "author": "Garvae",
  "publishConfig": {
    "access": "public"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run pre-commit"
    }
  },
  "devDependencies": {
    "@babel/cli": "^7.17.0",
    "@babel/core": "^7.17.0",
    "@babel/generator": "^7.18.12",
    "@babel/parser": "^7.18.11",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-object-rest-spread": "^7.16.7",
    "@babel/plugin-proposal-optional-chaining": "^7.18.9",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-modules-commonjs": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.18.10",
    "@babel/preset-env": "^7.18.10",
    "@babel/preset-react": "^7.16.7",
    "@babel/preset-typescript": "^7.16.7",
    "@babel/runtime": "^7.18.9",
    "@biomejs/biome": "^2.5.0",
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-node-resolve": "^13.1.3",
    "@rollup/plugin-replace": "^3.0.1",
    "@size-limit/preset-small-lib": "^8.0.1",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^13.0.0",
    "@testing-library/user-event": "^13.2.1",
    "@types/jest": "^28.1.6",
    "@types/node": "^18.7.13",
    "@types/node-sass": "^4.11.3",
    "@types/react": "^18.0.17",
    "@types/react-dom": "^18.0.6",
    "babel-jest": "^28.1.3",
    "babel-plugin-react-css-modules": "^5.2.6",
    "babel-plugin-transform-postcss": "^0.3.0",
    "cpx": "^1.5.0",
    "del": "^8.0.1",
    "husky": "^8.0.1",
    "is-ci": "^3.0.0",
    "jest": "^28.1.3",
    "jest-environment-jsdom": "^28.1.3",
    "jsdoc": "^3.6.10",
    "jsdoc-babel": "^0.5.0",
    "jsdoc-to-markdown": "^7.1.1",
    "lint-staged": "^12.3.7",
    "node-sass": "^7.0.1",
    "pre-commit": "^1.2.2",
    "prepend": "^1.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-overlay": "6.0.9",
    "rimraf": "^6.1.3",
    "rollup": "^2.67.3",
    "rollup-plugin-analyzer": "^4.0.0",
    "rollup-plugin-license": "^2.8.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-typescript2": "^0.31.2",
    "size-limit": "^8.0.1",
    "ts-jest": "^28.0.7",
    "ts-loader": "^9.2.6",
    "ts-node": "^10.4.0",
    "tslib": "^2.4.0",
    "typescript": "^4.6.4"
  }
}
